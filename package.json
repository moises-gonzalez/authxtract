{
  "name": "authxtract",
  "version": "0.2.0",
  "description": "Securely extract and manage authentication state from web pages",
  "main": "dist/index.js",
  "bin": {
    "authxtract": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx ts-node src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"playwright.config.ts\"",
    "test:unit": "node --require ts-node/register/transpile-only tests/unit/storage.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "playwright",
    "authentication",
    "testing",
    "automation"
  ],
  "author": "Moises Gonzalez <moises.gonzalez@simpat.tech>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moises-gonzalez/authxtract.git"
  },
  "bugs": {
    "url": "https://github.com/moises-gonzalez/authxtract/issues"
  },
  "homepage": "https://github.com/moises-gonzalez/authxtract#readme",
  "type": "commonjs",
  "dependencies": {
    "commander": "^13.0.0",
    "playwright": "^1.57.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.9",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.61.0"
  }
}
